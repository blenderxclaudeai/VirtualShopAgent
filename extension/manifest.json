{
  "manifest_version": 3,
  "name": "VirtualShopAgent",
  "version": "0.1.0",
  "description": "AI-driven visual try-on overlay for ecommerce sites",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VirtualShopAgent"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
