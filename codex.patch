+def render_vto(payload: RenderRequest) -> dict:
+    """Temporary mocked endpoint for extension integration testing."""
+    _ = payload
+    return {
+        "result_image_url": "https://picsum.photos/900/1200",
+        "status": "mocked"
+    }
